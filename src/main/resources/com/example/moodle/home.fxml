<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>


<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.moodle.controller.HomeController">

    <!-- ================= NAVBAR ================= -->
    <top>
        <HBox spacing="20"
              alignment="CENTER_LEFT"
              style="-fx-padding: 15;">

            <Label text="MOODLE 2.0"
                   styleClass="title-label"/>

            <Button text="⌂ Home" styleClass="nav-btn" onAction="#goHome"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Your Campus -->
            <Button fx:id="campusButton"
                    text="My Campus"
                    onAction="#goToCampus"/>

            <!-- My Profile Button (visible when logged in) -->
            <Button fx:id="profileButton"
                    text="My Profile"
                    onAction="#goToProfile"
                    visible="false"/>

            <!-- Logout Button (visible when logged in) -->
            <Button fx:id="logoutButton"
                    text="Logout"
                    onAction="#logout"
                    visible="false"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>

            <!-- Sign Up Button -->
            <Button fx:id="signupButton"
                    text="Sign Up"
                    onAction="#goToSignup"
                    translateX="-14"/>

            <!-- Login Button -->
            <Button fx:id="loginButton"
                    text="Login"
                    onAction="#goToLogin"
                    translateX="-14"/>

        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
   <center>

    <ScrollPane fitToWidth="true">

        <VBox spacing="60"
              alignment="TOP_CENTER">

            <padding>
                <Insets top="60" bottom="60"/>
            </padding>

            <!-- HERO -->
            <VBox spacing="15" alignment="CENTER">
                <Label text="Integrated University Platform"
                       styleClass="title-label"/>

                <Label text="Connecting Engineering, Medical, Agricultural and All Universities in One Smart System"
                       wrapText="true"
                       maxWidth="700"/>
            </VBox>

            <!-- SEARCH BAR -->
            <VBox spacing="8" alignment="CENTER" maxWidth="500">
                <TextField fx:id="searchField"
                           promptText="🔍  Search University (e.g. BUET, DU, BAU...)"
                           styleClass="search-field"/>
                <VBox fx:id="searchResults" spacing="4" visible="false"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);"/>
            </VBox>

            <!-- ABOUT -->
            <VBox spacing="15" maxWidth="800">
                <Label text="About"
                       styleClass="section-title"/>
                <Label wrapText="true"
                       text="Moodle 2.0 is a unified digital platform designed to manage and simulate university life across all institutions."/>
            </VBox>

            <!-- LATEST NEWS -->
            <VBox spacing="15" maxWidth="800">
                <Label text="Latest News"
                       styleClass="section-title"/>
                <Label text="• BUET wins International Robotics Competition"/>
                <Label text="• Medical Research Breakthrough"/>
                <Label text="• Agricultural Fair 2026 Announced"/>
            </VBox>

            <!-- UPCOMING EVENTS -->
            <VBox spacing="15" maxWidth="800">
                <Label text="Upcoming Events"
                       styleClass="section-title"/>
                <Label text="• Inter University Hackathon"/>
                <Label text="• National Conference"/>
                <Label text="• Debate Championship"/>
            </VBox>

                 <!-- ABOUT PROJECT (BOTTOM) -->
                 <VBox spacing="10" maxWidth="800"
                    style="-fx-padding: 18; -fx-background-color: #f8f9ff; -fx-background-radius: 12;">
                  <Label text="About Project"
                      styleClass="section-title"/>

                  <Label wrapText="true"
                      text="Goal: Build one simple, student-friendly platform where academic tools, campus services, and communication stay connected in one place."/>

                  <Label text="Developers"
                      style="-fx-font-weight: bold; -fx-padding: 4 0 0 0;"/>
                  <Label text="Md. Raihan Kabir Sifat"/>
                  <Label text="CSE, BUET" style="-fx-text-fill: #666;"/>
                  <Label text="Khandokar Naeemul Haque" style="-fx-padding: 8 0 0 0;"/>
                  <Label text="CSE, BUET" style="-fx-text-fill: #666;"/>
                 </VBox>

                 <!-- CONTACT (BOTTOM) -->
                 <VBox spacing="10" maxWidth="800"
                    style="-fx-padding: 18; -fx-background-color: #ffffff; -fx-background-radius: 12;">
                  <Label text="Contact"
                      styleClass="section-title"/>
                  <Label wrapText="true"
                      text="For project queries or collaboration, please contact the Moodle 2.0 team through CSE, BUET channels."/>
                 </VBox>

        </VBox>

    </ScrollPane>

</center>

    <!-- ================= BOTTOM NAV ================= -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 15;">
            <Button text="← Back" styleClass="nav-btn" onAction="#goBack"/>
        </HBox>
    </bottom>

</BorderPane>