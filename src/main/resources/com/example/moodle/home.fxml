<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>


<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.moodle.controller.HomeController">

    <!-- ================= NAVBAR ================= -->
    <top>
          <HBox spacing="20"
              alignment="CENTER_LEFT"
              styleClass="top-bar"
              style="-fx-padding: 15;">

            <Label text="MOODLE 2.0"
                   styleClass="title-label"/>

            <Button text="⌂ Home" styleClass="nav-btn" onAction="#goHome"/>
                 <Button text="+ Connect" styleClass="nav-btn" onAction="#showNetworkPanel"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Your Campus -->
            <Button fx:id="campusButton"
                    text="My Campus"
                    onAction="#goToCampus"/>

            <!-- My Profile Button (visible when logged in) -->
            <Button fx:id="profileButton"
                    text="My Profile"
                    onAction="#goToProfile"
                    visible="false"/>

            <!-- Logout Button (visible when logged in) -->
            <Button fx:id="logoutButton"
                    text="Logout"
                    onAction="#logout"
                    visible="false"
                    styleClass="cyber-btn-danger"/>

            <MenuButton fx:id="themeMenuButton"
                        text="Mode"
                        styleClass="mode-menu">
                <items>
                    <MenuItem text="Dark" onAction="#setDarkMode"/>
                    <MenuItem text="Light" onAction="#setLightMode"/>
                </items>
            </MenuButton>

            <!-- Sign Up Button -->
            <Button fx:id="signupButton"
                    text="Sign Up"
                    onAction="#goToSignup"
                    translateX="-14"/>

            <!-- Login Button -->
            <Button fx:id="loginButton"
                    text="Login"
                    onAction="#goToLogin"
                    translateX="-14"/>

        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
   <center>

    <ScrollPane fitToWidth="true">

          <VBox fx:id="homeContentBox"
              spacing="60"
              alignment="TOP_CENTER"
              styleClass="home-content">

            <padding>
                <Insets top="60" bottom="60"/>
            </padding>

            <!-- HERO -->
                 <VBox fx:id="heroBox" spacing="15" alignment="CENTER" styleClass="hero-card">
                  <Label text="🌍 Integrated University Platform"
                       styleClass="title-label"/>

                <Label text="Connecting Engineering, Medical, Agricultural and All Universities in One Smart System"
                      styleClass="hero-subtitle"
                       wrapText="true"
                       maxWidth="700"/>
            </VBox>

            <!-- SEARCH BAR -->
            <VBox spacing="8" alignment="CENTER" maxWidth="500">
                <TextField fx:id="searchField"
                           promptText="🔍  Search University (e.g. BUET, DU, BAU...)"
                           styleClass="search-field"/>
                    <VBox fx:id="searchResults" spacing="4" visible="false"
                        styleClass="search-results-panel"/>
            </VBox>

                 <!-- NETWORK MESSAGING CONNECT -->
                     <VBox fx:id="networkPanel" spacing="10" maxWidth="840" styleClass="glass-card"
                         visible="false" managed="false">
                  <Label text="Network Messaging"
                      styleClass="section-title"/>
                  <Label text="To chat across laptops, enter the other laptop server address and connect."
                      wrapText="true"/>

                  <HBox spacing="10" alignment="CENTER_LEFT">
                      <TextField fx:id="serverAddressField"
                           promptText="Server address (example: 192.168.0.42:50555)"
                           HBox.hgrow="ALWAYS"
                           onAction="#connectToServer"/>
                      <Button fx:id="connectServerButton"
                        text="Connect"
                        onAction="#connectToServer"/>
                      <Button fx:id="disconnectServerButton"
                        text="Disconnect"
                        onAction="#disconnectFromServer"
                        styleClass="cyber-btn-danger"/>
                  </HBox>

                  <Label fx:id="localServerLabel"
                      text="Local IP:"
                      wrapText="true"/>
                  <Label fx:id="networkStatusLabel"
                      text="Not connected"
                      wrapText="true"/>
                 </VBox>

            <!-- LATEST NEWS -->
            <VBox spacing="16" maxWidth="1100" prefWidth="1100" styleClass="news-wall">
                <Label text="🗞 Latest News"
                       styleClass="section-title"/>

                <GridPane hgap="20" vgap="20" styleClass="news-grid-wide">

                    <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image"
                                   onMouseClicked="#openBuetVlog">
                            <image>
                                <Image url="@news/BUET_Team_BUET_Silver_hawks.jpg"/>
                            </image>
                        </ImageView>
                        <Label text="BUET Participated in ICPC Regional Final"
                               wrapText="true"
                               onMouseClicked="#openBuetVlog"
                               styleClass="news-headline news-clickable"/>
                        <Label text="ICPC regional final journey and team highlights."
                               onMouseClicked="#openBuetVlog"
                               styleClass="news-meta news-clickable"/>
                    </VBox>

                    <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image"
                                   onMouseClicked="#openDhakaMedicalVlog">
                            <image>
                                <Image url="@news/dhaka-medical-beds.png"/>
                            </image>
                        </ImageView>
                           <Label text="Dhaka Medical to Become 5,000-Bed State-of-the-Art Hospital"
                               wrapText="true"
                               onMouseClicked="#openDhakaMedicalVlog"
                               styleClass="news-headline news-clickable"/>
                           <Label text="27 new multi-storey buildings will modernize treatment and medical education."
                               onMouseClicked="#openDhakaMedicalVlog"
                               styleClass="news-meta news-clickable"/>
                    </VBox>

                    <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="0" GridPane.rowIndex="1">
                        <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image"
                                   onMouseClicked="#openFutureVlogOne">
                            <image>
                                <Image url="@news/future-vlog-1.jpg"/>
                            </image>
                        </ImageView>
                           <Label text="KUET Graduate Mahin Rahman Starts Master's at ASU"
                               wrapText="true"
                               onMouseClicked="#openFutureVlogOne"
                               styleClass="news-headline news-clickable"/>
                           <Label text="Fully funded scholarship recipient now serving as a Graduate Research Assistant."
                               onMouseClicked="#openFutureVlogOne"
                               styleClass="news-meta news-clickable"/>
                    </VBox>

                    <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image"
                                   onMouseClicked="#openFutureVlogTwo">
                            <image>
                                <Image url="@news/future-vlog-2.jpg"/>
                            </image>
                        </ImageView>
                           <Label text="BAU Student Develops Sensor-Based AI for Livestock Farms"
                               wrapText="true"
                               onMouseClicked="#openFutureVlogTwo"
                               styleClass="news-headline news-clickable"/>
                           <Label text="Innovation monitors farm climate to reduce animal heat stress and improve productivity."
                               onMouseClicked="#openFutureVlogTwo"
                               styleClass="news-meta news-clickable"/>
                    </VBox>

                </GridPane>
            </VBox>

            <!-- UPCOMING EVENTS -->
            <VBox spacing="15" maxWidth="800" styleClass="glass-card">
                <Label text="🎉 Upcoming Events"
                       styleClass="section-title"/>
                <Label text="• Inter University Hackathon"/>
                <Label text="• National Conference"/>
                <Label text="• Debate Championship"/>
            </VBox>

            <!-- BOTTOM TWO-COLUMN FOOTER -->
            <HBox spacing="20" maxWidth="1060" alignment="TOP_CENTER" styleClass="footer-row">
                <VBox spacing="10" maxWidth="500" styleClass="footer-card" HBox.hgrow="ALWAYS">
                    <Label text="🚀 About Project"
                           styleClass="section-title"/>

                    <Label wrapText="true"
                           text="Goal: Build one simple, student-friendly platform where academic tools, campus services, and communication stay connected in one place."/>

                    <Label text="Developers"
                           style="-fx-font-weight: bold; -fx-padding: 4 0 0 0; -fx-text-fill: #ffb300;"/>
                    <Label text="Md. Raihan Kabir Sifat"/>
                    <Label text="CSE, BUET" style="-fx-text-fill: #5a6a7e;"/>
                    <Label text="Khandokar Naeemul Haque" style="-fx-padding: 8 0 0 0;"/>
                    <Label text="CSE, BUET" style="-fx-text-fill: #5a6a7e;"/>
                </VBox>

                <VBox spacing="10" maxWidth="500" styleClass="footer-card" HBox.hgrow="ALWAYS">
                    <Label text="📬 Contact"
                           styleClass="section-title"/>
                    <Label wrapText="true"
                           text="For project queries or collaboration, please contact the Moodle 2.0 team through CSE, BUET channels."/>
                </VBox>
            </HBox>

        </VBox>

    </ScrollPane>

</center>

    <!-- ================= BOTTOM NAV ================= -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" styleClass="bottom-bar" style="-fx-padding: 15;">
            <Button text="← Back" styleClass="nav-btn" onAction="#goBack"/>
        </HBox>
    </bottom>

</BorderPane>