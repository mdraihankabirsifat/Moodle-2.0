<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.moodle.controller.HomeController"
            styleClass="root">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox spacing="15" styleClass="side-nav" prefWidth="250" style="-fx-padding: 30 20 30 20;">
            <Label text="MOODLE 2.0" styleClass="title-label" style="-fx-padding: 0 0 20 0; -fx-font-size: 22px;"/>
            <Button fx:id="loginButton" text="Login" styleClass="nav-btn" onAction="#goToLogin" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            <Button fx:id="signupButton" text="Sign Up" styleClass="nav-btn" onAction="#goToSignup" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            <Button fx:id="campusButton" text="My Campus" styleClass="nav-btn" onAction="#goToCampus" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            <Button text="Connect" styleClass="nav-btn" onAction="#showNetworkPanel" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            <Button text="About" styleClass="nav-btn" onAction="#showAbout" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            <Button text="Help" styleClass="nav-btn" onAction="#showHelp" maxWidth="Infinity" alignment="CENTER_LEFT"/>
            
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="logoutButton" text="Logout" styleClass="cyber-btn-danger" onAction="#logout" visible="false" managed="false" maxWidth="Infinity" alignment="CENTER_LEFT"/>
        </VBox>
    </left>

    <!-- ================= CENTER CONTENT ================= -->
    <center>
        <BorderPane>
            <!-- TOP HEADER -->
            <top>
                <VBox>
                    <HBox spacing="15" alignment="CENTER" style="-fx-padding: 40 30 10 30;">
                        <Region HBox.hgrow="ALWAYS"/>
                        
                        <!-- SEARCH BAR -->
                        <HBox spacing="8" alignment="CENTER">
                            <Label text="🔍" style="-fx-text-fill: #5a6a7e; -fx-font-size: 16px;"/>
                            <TextField fx:id="searchField" promptText="Search University..." styleClass="search-field" prefWidth="400"/>
                        </HBox>
                        
                        <Region HBox.hgrow="ALWAYS"/>
                        
                        <!-- My Profile Button (visible when logged in) -->
                        <Button fx:id="profileButton" text="My Profile" onAction="#goToProfile" visible="false" managed="false" styleClass="nav-btn"/>
                        
                        <!-- Notification Menu -->
                        <MenuButton fx:id="notificationMenu" visible="false" managed="false" text="🔔 (3)" styleClass="mode-menu">
                            <items>
                                <MenuItem text="System Admin: Welcome to Moodle 2.0!"/>
                                <MenuItem text="Instructor: New assignment uploaded."/>
                                <MenuItem text="Institutional Notice: Hackathon registration live!"/>
                            </items>
                        </MenuButton>
                        
                        <!-- Mode Menu -->
                        <MenuButton fx:id="themeMenuButton" text="Mode" styleClass="mode-menu">
                            <items>
                                <MenuItem text="Dark" onAction="#setDarkMode"/>
                                <MenuItem text="Light" onAction="#setLightMode"/>
                            </items>
                        </MenuButton>
                    </HBox>

                    <!-- SEARCH RESULTS PANEL -->
                    <HBox alignment="CENTER">
                        <VBox fx:id="searchResults" spacing="4" visible="false" managed="false" styleClass="search-results-panel" prefWidth="400" maxWidth="400"/>
                    </HBox>
                </VBox>
            </top>

            <!-- SCROLLABLE MAIN CONTENT -->
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox fx:id="homeContentBox" spacing="50" alignment="TOP_CENTER" styleClass="home-content">
                        <padding>
                            <Insets top="60" bottom="60"/>
                        </padding>

                        <!-- HERO -->
                        <VBox fx:id="heroBox" spacing="15" alignment="CENTER" styleClass="hero-card">
                            <Label text="🌍 Integrated University Platform" styleClass="title-label"/>
                            <Label text="Connecting Engineering, Medical, Agricultural and All Universities in One Smart System"
                                   styleClass="hero-subtitle" wrapText="true" maxWidth="700"/>
                        </VBox>

                        <!-- ACTIVITY TRACKER (Github-style) -->
                        <VBox fx:id="activityTrackerPanel" spacing="12" alignment="CENTER" maxWidth="840"
                              styleClass="glass-card" visible="false" managed="false">
                            <Label fx:id="activityTrackerTitle" text="Activities in the last year"
                                   styleClass="section-title"/>
                            <HBox alignment="CENTER" spacing="10">
                                <VBox fx:id="activityDaysLabels" spacing="4" alignment="TOP_RIGHT"/>
                                <!-- The grid container -->
                                <HBox fx:id="activityGridContainer" spacing="4" alignment="CENTER_LEFT"/>
                            </HBox>
                            <HBox alignment="CENTER_RIGHT" spacing="6" style="-fx-padding: 5 20 0 0;">
                                <Label text="Less" style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"/>
                                <Region style="-fx-background-color: #0e4429; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 2;"/>
                                <Region style="-fx-background-color: #006d32; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 2;"/>
                                <Region style="-fx-background-color: #26a641; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 2;"/>
                                <Region style="-fx-background-color: #39d353; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 2;"/>
                                <Label text="More" style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"/>
                            </HBox>
                        </VBox>

                        <!-- NETWORK MESSAGING CONNECT -->
                        <VBox fx:id="networkPanel" spacing="10" maxWidth="840" styleClass="glass-card"
                              visible="false" managed="false">
                            <Label text="Network Messaging" styleClass="section-title"/>
                            <Label text="To chat across laptops, enter the other laptop server address and connect." wrapText="true"/>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <TextField fx:id="serverAddressField" promptText="Server address (example: 192.168.0.42:50555)" HBox.hgrow="ALWAYS" onAction="#connectToServer"/>
                                <Button fx:id="connectServerButton" text="Connect" onAction="#connectToServer"/>
                                <Button fx:id="disconnectServerButton" text="Disconnect" onAction="#disconnectFromServer" styleClass="cyber-btn-danger"/>
                            </HBox>

                            <Label fx:id="localServerLabel" text="Local IP:" wrapText="true"/>
                            <Label fx:id="networkStatusLabel" text="Not connected" wrapText="true"/>
                        </VBox>

                        <!-- LATEST NEWS -->
                        <VBox spacing="16" styleClass="news-wall" alignment="CENTER">
                            <Label text="🗞 Latest News" styleClass="section-title" alignment="CENTER"/>

                            <GridPane hgap="20" vgap="20" styleClass="news-grid-wide" alignment="CENTER">
                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image" onMouseClicked="#openBuetVlog">
                                        <image>
                                            <Image url="@news/BUET_Team_BUET_Silver_hawks.jpg"/>
                                        </image>
                                    </ImageView>
                                    <Label text="BUET Participated in ICPC Regional Final" wrapText="true" onMouseClicked="#openBuetVlog" styleClass="news-headline news-clickable"/>
                                    <Label text="ICPC regional final journey and team highlights." onMouseClicked="#openBuetVlog" styleClass="news-meta news-clickable"/>
                                </VBox>

                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image" onMouseClicked="#openDhakaMedicalVlog">
                                        <image>
                                            <Image url="@news/dhaka-medical-beds.png"/>
                                        </image>
                                    </ImageView>
                                    <Label text="Dhaka Medical to Become 5,000-Bed State-of-the-Art Hospital" wrapText="true" onMouseClicked="#openDhakaMedicalVlog" styleClass="news-headline news-clickable"/>
                                    <Label text="27 new multi-storey buildings will modernize treatment and medical education." onMouseClicked="#openDhakaMedicalVlog" styleClass="news-meta news-clickable"/>
                                </VBox>

                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image" onMouseClicked="#openFutureVlogOne">
                                        <image>
                                            <Image url="@news/future-vlog-1.jpg"/>
                                        </image>
                                    </ImageView>
                                    <Label text="KUET Graduate Mahin Rahman Starts Master's at ASU" wrapText="true" onMouseClicked="#openFutureVlogOne" styleClass="news-headline news-clickable"/>
                                    <Label text="Fully funded scholarship recipient now serving as a Graduate Research Assistant." onMouseClicked="#openFutureVlogOne" styleClass="news-meta news-clickable"/>
                                </VBox>

                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <ImageView fitWidth="420" fitHeight="230" preserveRatio="false" styleClass="news-image" onMouseClicked="#openFutureVlogTwo">
                                        <image>
                                            <Image url="@news/future-vlog-2.jpg"/>
                                        </image>
                                    </ImageView>
                                    <Label text="BAU Student Develops Sensor-Based AI for Livestock Farms" wrapText="true" onMouseClicked="#openFutureVlogTwo" styleClass="news-headline news-clickable"/>
                                    <Label text="Innovation monitors farm climate to reduce animal heat stress and improve productivity." onMouseClicked="#openFutureVlogTwo" styleClass="news-meta news-clickable"/>
                                </VBox>
                            </GridPane>
                        </VBox>

                        <!-- UPCOMING EVENTS -->
                        <VBox spacing="16" styleClass="news-wall" alignment="CENTER">
                            <Label text="🎉 Upcoming Events" styleClass="section-title" alignment="CENTER"/>

                            <GridPane hgap="20" vgap="20" styleClass="news-grid-wide" alignment="CENTER">
                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Inter University Hackathon" wrapText="true" styleClass="news-headline news-clickable"/>
                                    <Label text="Bring your team and showcase your coding skills. Great prizes and opportunities await." styleClass="news-meta news-clickable"/>
                                </VBox>

                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="National Conference on Technologies" wrapText="true" styleClass="news-headline news-clickable"/>
                                    <Label text="Annual gathering of the brightest minds discussing recent scientific breakthroughs." styleClass="news-meta news-clickable"/>
                                </VBox>

                                <VBox spacing="10" styleClass="news-card-large" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <Label text="National Debate Championship" wrapText="true" styleClass="news-headline news-clickable"/>
                                    <Label text="The ultimate debating contest opens its gates for institutional registration." styleClass="news-meta news-clickable"/>
                                </VBox>
                            </GridPane>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>