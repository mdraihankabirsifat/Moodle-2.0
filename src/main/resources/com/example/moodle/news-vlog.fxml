<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.moodle.controller.NewsVlogController">

    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="top-bar" style="-fx-padding: 15;">
            <Label text="NEWS VLOG" styleClass="title-label"/>
            <Button text="⌂ Home" styleClass="nav-btn" onAction="#goHome"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Back" styleClass="nav-btn" onAction="#goBack"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true">
            <HBox spacing="30" maxWidth="1280" alignment="TOP_LEFT" styleClass="vlog-page" style="-fx-padding: 34 28 34 28;">
                <ImageView fx:id="vlogImage" fitWidth="650" fitHeight="600" preserveRatio="true" smooth="true" styleClass="vlog-image"/>

                <VBox spacing="12" styleClass="glass-card" maxWidth="500" HBox.hgrow="ALWAYS">
                    <Label fx:id="vlogTitle" styleClass="vlog-title" wrapText="true"/>
                    <Label fx:id="vlogSummary" styleClass="vlog-summary" wrapText="true"/>
                    <Label fx:id="vlogStory" styleClass="vlog-story" wrapText="true"/>
                </VBox>
            </HBox>
        </ScrollPane>
    </center>

</BorderPane>
