<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.moodle.controller.AuthorityDashboardController">

    <!-- TOP -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="top-bar" style="-fx-padding: 15;">
            <Button text="⌂ Home" styleClass="nav-btn" onAction="#goHome"/>
            <Button text="My Campus" styleClass="nav-btn" onAction="#goToCampus"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Authority Dashboard"
                   styleClass="title-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔲 New Window" onAction="#openNewWindow"
                    styleClass="cyber-btn-accent" style="-fx-font-size: 11px;"/>
            <Button text="Sign Out" onAction="#signOutCampus"
                    styleClass="cyber-btn-danger"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent;">
            <VBox spacing="10"
                                                                        prefWidth="220"
                                                                        styleClass="side-nav"
                  style="-fx-padding: 20;">

                                                                <Label text="DATABASE" styleClass="nav-section-label"/>

                <Button text="Student Database"
                        onAction="#showStudentDatabase"
                        maxWidth="Infinity"/>

                <Button text="Edit Student"
                        onAction="#showEditStudent"
                        maxWidth="Infinity"/>

                <Label text="MANAGEMENT" styleClass="nav-section-label" style="-fx-padding: 10 0 0 0;"/>

                <Button text="Manage Notices"
                        onAction="#showManageNotices"
                        maxWidth="Infinity"/>

                <Button text="Payment Overview"
                        onAction="#showPaymentOverview"
                        maxWidth="Infinity"/>

                <Button text="📝 Edit Gradesheet"
                        onAction="#showEditGradesheet"
                        maxWidth="Infinity"/>

                <Label text="SYSTEM" styleClass="nav-section-label" style="-fx-padding: 10 0 0 0;"/>

                <Button text="System Overview"
                        onAction="#showSystemOverview"
                        maxWidth="Infinity"/>

                <Label text="CAMPUS FACILITIES" styleClass="nav-section-label" style="-fx-padding: 10 0 0 0;"/>

                <Button text="🏟 Manage Games"
                        onAction="#showManageGames"
                        maxWidth="Infinity"/>

                <Button text="🏥 Manage Hospital"
                        onAction="#showManageHospital"
                        maxWidth="Infinity"/>

                <Button text="🏠 Manage Hall"
                        onAction="#showManageHall"
                        maxWidth="Infinity"/>

            </VBox>
        </ScrollPane>
    </left>

    <!-- DYNAMIC CONTENT -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-padding: 30;"/>
    </center>

    <!-- BOTTOM NAV -->
    <bottom>
                <HBox alignment="CENTER_RIGHT" styleClass="bottom-bar" style="-fx-padding: 15;">
            <Button text="← Back" styleClass="nav-btn" onAction="#goBack"/>
        </HBox>
    </bottom>

</BorderPane>
