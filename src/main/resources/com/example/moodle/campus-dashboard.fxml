<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.moodle.controller.CampusDashboardController">

    <!-- TOP -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="top-bar" style="-fx-padding: 15;">
            <Button text="⌂ Home" styleClass="nav-btn" onAction="#goHome"/>
            <Button text="My Campus" styleClass="nav-btn" onAction="#goToCampus"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Campus Dashboard"
                   styleClass="title-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="🔲 New Window" onAction="#openNewWindow"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-size: 11px;"/>
            <Button text="Sign Out" onAction="#signOutCampus"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 6; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                    style="-fx-background-color: transparent;">
            <VBox spacing="10"
                        prefWidth="220"
                        styleClass="side-nav"
                  style="-fx-padding: 20;">

                <Button text="Internal Notices"
                        onAction="#showNotices"
                        maxWidth="Infinity"/>

                <Button text="My Courses"
                        onAction="#showCourses"
                        maxWidth="Infinity"/>

                <Button text="Gradesheet"
                        onAction="#showGradesheet"
                        maxWidth="Infinity"/>

                <Button text="Messages"
                        onAction="#showMessages"
                        maxWidth="Infinity"/>

                <Button text="🌐 Community"
                        onAction="#showCommunity"
                        maxWidth="Infinity"/>

                <Button text="Payment"
                        onAction="#showPayment"
                        maxWidth="Infinity"/>

                <Button text="Well Being"
                        onAction="#showWellBeing"
                        maxWidth="Infinity"/>

            </VBox>
        </ScrollPane>
    </left>

    <!-- DYNAMIC CONTENT -->
    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-padding: 30;"/>
    </center>

    <!-- ================= BOTTOM NAV ================= -->
    <bottom>
                <HBox alignment="CENTER_RIGHT" styleClass="bottom-bar" style="-fx-padding: 15;">
            <Button text="← Back" styleClass="nav-btn" onAction="#goBack"/>
        </HBox>
    </bottom>

</BorderPane>